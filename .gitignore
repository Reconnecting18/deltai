# Python
*.egg-info/
project/venv/
venv/
project/__pycache__/
project/*.pyc
project/.env
**/__pycache__/
*.pyc
*.pyo
fix.py

# Node / Electron
app/node_modules/
app/.cache/

# Ollama models — too large, typically stored in ~/.ollama/
# Do NOT commit model weights

# Data / memory stores
data/chromadb/
data/sqlite/
project/~/.local/share/

# Knowledge base files (PDFs, docs) — add manually if desired
# data/knowledge/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
npm-debug.log*

# Engine (C++ — separate build pipeline)
engine/

# Docs / reports (generated, not source)
docs/**
!docs/local-model-workflow.md
reports/
E3N_PROJECT_HANDOFF.md

# Backups
project/static/index.backup*.html

# Pip logs
pip_err.txt
pip_out.txt

# Local Claude config
project/.claude/

# Standalone JS (bundled into index.html)
project/static/js/

# Training data / exports
data/training/

# AI transparency reports (local dev when DELTA_DATA_DIR points at ./data)
data/ai_reports/

# Knowledge base files (add manually if desired)
data/knowledge/

# External tools (cloned repos)
tools/llama.cpp/

# Extensions — personal extensions are git-ignored by default.
# To track an extension: git add -f project/extensions/my_feature/
project/extensions/*/
!project/extensions/example_extension/
!project/extensions/arch_update_guard/
!project/extensions/training/
!project/extensions/__init__.py
!project/extensions/README.md

# Temp
*.tmp
*.bak
test_tts.mp3
project/tests/test_chromadb/
project/tests/test_deltai.db
project/tests/training_data/
project/tests/exports/
