# Copy to .env and edit:  cp .env.example .env
# Loaded from the project/ directory (python-dotenv in main.py).

# ── Ollama (local models) ───────────────────────────────────────────────────
OLLAMA_URL=http://127.0.0.1:11434

# Router defaults use Ollama *names* you create (see modelfiles/); override with raw tags if needed.
DELTAI_STRONG_MODEL=deltai-qwen14b
DELTAI_MODEL=deltai-qwen3b
DELTAI_SIM_MODEL=

# Optional quant tier overrides (see router.py)
# DELTAI_STRONG_MODEL_Q6=
# DELTAI_STRONG_MODEL_Q3=
# DELTAI_MODEL_Q2=

# If you use raw Ollama pulls instead of deltai-* Modelfiles, set tags on STRONG/MODEL above, e.g.:
# DELTAI_STRONG_MODEL=qwen2.5:14b-instruct-q4_K_M
# DELTAI_MODEL=qwen2.5:3b-instruct-q4_K_M

# ── Cloud (optional — dormant until ANTHROPIC_API_KEY is set) ────────────────
CLOUD_ENABLED=true
ANTHROPIC_API_KEY=
ANTHROPIC_SONNET_MODEL=claude-sonnet-4-20250514
ANTHROPIC_OPUS_MODEL=claude-opus-4-20250514
CLOUD_BUDGET_DAILY=5.00

# ── Intelligence ─────────────────────────────────────────────────────────────
REACT_ENABLED=true
REACT_MAX_ITERATIONS=3
RAR_ENABLED=true
SMART_HISTORY_ENABLED=true
KNOWLEDGE_GAP_DETECTION=true

# ── Resource / VRAM routing ──────────────────────────────────────────────────
VRAM_TIER_A_MIN_MB=9000
VRAM_TIER_AB_MIN_MB=5000
VRAM_TIER_B_MIN_MB=3000
WARM_TO_COLD_AGE_SEC=86400
INGEST_QUEUE_MAX=500

# ── SQLite (matches XDG / systemd delta-daemon defaults) ─────────────────────
# DELTA_SQLITE_PATH=~/.local/share/deltai/delta.db
# SQLITE_PATH=   # legacy alias for DELTA_SQLITE_PATH

# ── Training (optional) ──────────────────────────────────────────────────────
HF_BASE_MODEL=Qwen/Qwen2.5-3B-Instruct
DAILY_TRAIN_ENABLED=false
SMART_CAPTURE_ENABLED=true
