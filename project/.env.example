# Copy to .env and edit:  cp .env.example .env
# Loaded from the project/ directory (python-dotenv in main.py).

# ── Ollama (local models) ───────────────────────────────────────────────────
OLLAMA_URL=http://127.0.0.1:11434

# Router defaults use Ollama *names* you create (see modelfiles/); override with raw tags if needed.
DELTAI_STRONG_MODEL=deltai-qwen14b
DELTAI_MODEL=deltai-qwen3b
DELTAI_SIM_MODEL=

# Optional quant tier overrides (see router.py)
# DELTAI_STRONG_MODEL_Q6=
# DELTAI_STRONG_MODEL_Q3=
# DELTAI_MODEL_Q2=

# Local sampling (passed to Ollama /api/chat options; defaults shown)
# DELTAI_OLLAMA_TEMPERATURE=0.2
# DELTAI_OLLAMA_TOP_P=0.95

# Split workload (local tools + cloud synthesis): optional stronger synth model and planner pass
# DELTAI_SPLIT_SYNTH_MODEL=
# DELTAI_SPLIT_PLANNER_ENABLED=false
# DELTAI_SPLIT_PLANNER_MODEL=

# MCP (optional: pip install -e ".[mcp]" from repo root)
# Stdio: run `deltai-mcp` or `cd project && python deltai_mcp_stdio.py`
# HTTP: mount Streamable MCP on this FastAPI app (default off)
# DELTAI_MCP_HTTP_ENABLE=false
# DELTAI_MCP_HTTP_PATH=/mcp
# DELTAI_MCP_HTTP_KEY=

# If you use raw Ollama pulls instead of deltai-* Modelfiles, set tags on STRONG/MODEL above, e.g.:
# DELTAI_STRONG_MODEL=qwen2.5:14b-instruct-q4_K_M
# DELTAI_MODEL=qwen2.5:3b-instruct-q4_K_M

# ── Cloud (optional — dormant until ANTHROPIC_API_KEY is set) ────────────────
CLOUD_ENABLED=true
ANTHROPIC_API_KEY=
ANTHROPIC_SONNET_MODEL=claude-sonnet-4-20250514
ANTHROPIC_OPUS_MODEL=claude-opus-4-20250514
CLOUD_BUDGET_DAILY=5.00

# ── Intelligence ─────────────────────────────────────────────────────────────
REACT_ENABLED=true
REACT_MAX_ITERATIONS=3
RAR_ENABLED=true
SMART_HISTORY_ENABLED=true
KNOWLEDGE_GAP_DETECTION=true

# ── Resource / VRAM routing ──────────────────────────────────────────────────
VRAM_TIER_A_MIN_MB=9000
VRAM_TIER_AB_MIN_MB=5000
VRAM_TIER_B_MIN_MB=3000
WARM_TO_COLD_AGE_SEC=86400
INGEST_QUEUE_MAX=500

# ── Tool policy (optional) ────────────────────────────────────────────────────
# When 1, the LLM may call arch_rollback_plan with dry_run=false and apply_etc=true
# (restores captured /etc from a snapshot when running as root). Default: off.
# DELTAI_TOOL_AUTO_APPROVE=false

# ── Security (optional) ───────────────────────────────────────────────────────
# If set, ingest + pipeline status + disk ingest require this key via
#   X-Deltai-Ingest-Key: ...   or   Authorization: Bearer ...
# DELTAI_INGEST_API_KEY=
# CORS allowlist (comma-separated); leave unset for allow all (*)
# DELTAI_CORS_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# ── Appwrite bridge (optional extension appwrite_bridge) ──────────────────────
# HTTPS Storage + Functions for cross-device file handoff (see /ext/appwrite_bridge/status).
# On a Linux workstation, you can mirror these into ~/.config/deltai/appwrite.env for
# appwrite_remote_storage_push (secrets stay on that host).
# DELTAI_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
# DELTAI_APPWRITE_PROJECT_ID=
# DELTAI_APPWRITE_API_KEY=
# DELTAI_APPWRITE_BUCKET_ID=

# ── SQLite (matches XDG / systemd delta-daemon defaults) ─────────────────────
# DELTA_SQLITE_PATH=~/.local/share/deltai/delta.db
# SQLITE_PATH=   # legacy alias for DELTA_SQLITE_PATH

# ── Training (optional) ──────────────────────────────────────────────────────
HF_BASE_MODEL=Qwen/Qwen2.5-3B-Instruct
DAILY_TRAIN_ENABLED=false
SMART_CAPTURE_ENABLED=true
