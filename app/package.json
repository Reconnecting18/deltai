{
  "name": "deltai",
  "version": "1.0.0",
  "description": "deltai — Local AI Assistant",
  "main": "main.js",
  "scripts": {
    "prestart": "node scripts/check-electron.cjs",
    "start": "node scripts/start-electron.js",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.deltai.assistant",
    "productName": "deltai",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "main.js",
      "assets/**"
    ]
  },
  "devDependencies": {
    "electron": "^39.8.5",
    "electron-builder": "^26.8.1"
  }
}
