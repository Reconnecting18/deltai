{
  "name": "e3n",
  "version": "1.0.0",
  "description": "E3N — Local AI Assistant",
  "main": "main.js",
  "scripts": {
    "prestart": "node scripts/check-electron.cjs",
    "start": "node scripts/start-electron.js",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.e3n.assistant",
    "productName": "E3N",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "main.js",
      "assets/**"
    ]
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
