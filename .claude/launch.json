{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "deltai Electron App",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["start"],
      "cwd": "${workspaceFolder}/app",
      "port": 8000,
      "autoPort": false
    },
    {
      "name": "deltai FastAPI Backend (venv)",
      "runtimeExecutable": "${workspaceFolder}/project/venv/Scripts/python.exe",
      "runtimeArgs": [
        "-m",
        "uvicorn",
        "main:app",
        "--host",
        "127.0.0.1",
        "--port",
        "8000"
      ],
      "cwd": "${workspaceFolder}/project",
      "port": 8000
    },
    {
      "name": "deltai FastAPI Backend (python on PATH)",
      "runtimeExecutable": "python",
      "runtimeArgs": [
        "-m",
        "uvicorn",
        "main:app",
        "--host",
        "127.0.0.1",
        "--port",
        "8000"
      ],
      "cwd": "${workspaceFolder}/project",
      "port": 8000
    }
  ]
}
