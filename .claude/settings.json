{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git diff)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git branch)",
      "Bash(git remote -v)",
      "Bash(git remote:*)",
      "Bash(git ls-files:*)",
      "Bash(git check-ignore:*)",
      "Bash(git config --get:*)",
      "Bash(ls:*)",
      "Bash(pwd)",
      "Bash(wc -l:*)",
      "Bash(file:*)",
      "Bash(python -m py_compile:*)",
      "Bash(python -m pyflakes:*)",
      "Bash(python -c:*)",
      "Bash(ruff check:*)",
      "Bash(ruff format --check:*)",
      "Bash(mypy:*)",
      "Bash(pytest:*)",
      "Bash(curl -sS http://127.0.0.1:8000/api/health)",
      "Bash(curl -sS http://127.0.0.1:8000/health)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd:*)",
      "Read(.env)",
      "Read(project/.env)",
      "Read(**/credentials*)",
      "Read(**/*.pem)",
      "Read(**/*.key)"
    ]
  }
}
